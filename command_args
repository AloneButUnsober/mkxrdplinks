xfreerdp 
-host -h -v Host-IPAddress
-user -u username
-cert -c ignore cert warnings/errors
-floatbar -fb "floatbar:sticky:on"
-domain -d domain name
-password -pw -p user password*
-disp Disp res settings
-dynamic-resolution -dynres -dr dynamic-resolution
-clipboard -clip -cl +clipboard

